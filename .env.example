# Popcorn Sales Manager - Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# OpenTofu Backend Encryption
# ============================================================================
# Generate with: openssl rand -base64 32
TF_VAR_encryption_passphrase=your-encryption-passphrase-here

# ============================================================================
# Google OAuth (Optional - required for Google social login)
# ============================================================================
# Get from: https://console.cloud.google.com/
TF_VAR_google_client_id=your-google-client-id
TF_VAR_google_client_secret=your-google-client-secret

# ============================================================================
# Test User Credentials (for create-test-users.sh script)
# ============================================================================
# Cognito User Pool ID (find with: aws cognito-idp list-user-pools --max-results 60)
TEST_USER_POOL_ID=your-user-pool-id

# AWS region where Cognito is deployed
TEST_REGION=us-east-1

# Owner test user
TEST_OWNER_EMAIL=owner@example.com
TEST_OWNER_PASSWORD=TestPassword123!

# Contributor test user
TEST_CONTRIBUTOR_EMAIL=contributor@example.com
TEST_CONTRIBUTOR_PASSWORD=TestPassword123!

# Read-only test user
TEST_READONLY_EMAIL=readonly@example.com
TEST_READONLY_PASSWORD=TestPassword123!

# ============================================================================
# E2E Testing
# ============================================================================
# Base URL for Playwright e2e tests (deployed frontend)
E2E_BASE_URL=https://dev.kernelworx.app

# DynamoDB table names are resolved automatically from E2E_BASE_URL + TEST_REGION
# using the naming convention: kernelworx-{type}-{region_abbrev}-{environment}
# (e.g. kernelworx-accounts-ue1-dev). Set any *_TABLE_NAME var below only to
# override a specific table.
# ACCOUNTS_TABLE_NAME=
# PROFILES_TABLE_NAME=
# CAMPAIGNS_TABLE_NAME=
# ORDERS_TABLE_NAME=
# SHARES_TABLE_NAME=
# CATALOGS_TABLE_NAME=
# INVITES_TABLE_NAME=
# SHARED_CAMPAIGNS_TABLE_NAME=
